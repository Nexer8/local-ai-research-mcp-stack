# -----------------------------------------------------------------------
# Port Configuration
# Change these values if you have conflicts with existing local services.
# -----------------------------------------------------------------------

# The port where SearXNG search engine will be exposed on your local machine
SEARXNG_PORT=8081

# The port where Crawl4AI will be exposed on your local machine
CRAWL4AI_PORT=8082

# The port where the MCP Server for SearXNG will be exposed
MCP_SEARXNG_PORT=8083

# The port where the MCP Server for Crawl4AI will be exposed
MCP_CRAWL4AI_PORT=8084
